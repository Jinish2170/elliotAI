# VERITAS Environment Variables Template
# Copy this file to .env and fill in your values

# ========================================
# NVIDIA NIM Configuration
# ========================================
NVIDIA_NIM_API_KEY=your_nvidia_api_key_here
NVIDIA_NIM_ENDPOINT=https://integrate.api.nvidia.com/v1
NIM_VISION_MODEL=meta/llama-3.2-90b-vision-instruct
NIM_VISION_FALLBACK=microsoft/phi-3.5-vision-instruct
NIM_LLM_MODEL=meta/llama-3.1-70b-instruct
NIM_TIMEOUT=90
NIM_RETRY_COUNT=4
NIM_REQUESTS_PER_MINUTE=40

# ========================================
# External Search APIs
# ========================================
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_REQUESTS_PER_MINUTE=5

# ========================================
# OSINT / CTI APIs
# ========================================
URLVOID_API_KEY=your_urlvoid_api_key_here
URLVOID_REQUESTS_PER_MINUTE=20
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
ABUSEIPDB_REQUESTS_PER_MINUTE=15
GOOGLE_SAFE_BROWSING_KEY=your_google_safe_browsing_key_here

# ========================================
# Configuration
# ========================================
# "true" or "false" - Enable database persistence
USE_DB_PERSISTENCE=true

# Browser settings
BROWSER_HEADLESS=true
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080
MOBILE_VIEWPORT_WIDTH=390
MOBILE_VIEWPORT_HEIGHT=844

# Audit tiers and budgets
DEFAULT_AUDIT_TIER=standard_audit
DEFAULT_VERDICT_MODE=expert
MAX_ITERATIONS=5
MAX_PAGES_PER_AUDIT=10
SCREENSHOT_TIMEOUT=25
TEMPORAL_DELAY=10
CONFIDENCE_THRESHOLD=0.6
MIN_EVIDENCE_COUNT=3

# Concurrency settings
MAX_CONCURRENT_AUDITS=2
MAX_CONCURRENT_BROWSER_PAGES=3
INTER_REQUEST_DELAY_MS=500

# Graph / OSINT settings
GRAPH_PHASE_TIMEOUT_S=150
GRAPH_WHOIS_TIMEOUT_S=20
GRAPH_DNS_TIMEOUT_S=12
GRAPH_SSL_TIMEOUT_S=20
GRAPH_META_TIMEOUT_S=30
GRAPH_VERIFY_TIMEOUT_S=30
GRAPH_SEARCH_TIMEOUT_S=25
GRAPH_VERIFY_CONCURRENCY=5
GRAPH_SEARCH_FOLLOW_LINKS=false
GRAPH_ENABLE_OSINT=true
GRAPH_OSINT_TIMEOUT_S=45
GRAPH_OSINT_MAX_PARALLEL=5
GRAPH_ENABLE_CTI=true
GRAPH_CTI_MIN_CONFIDENCE=0.3

# Security settings
ENABLED_SECURITY_MODURES=security_headers,phishing_db,tls_ssl,csp,gdpr,pci_dss,cookies,dom_analyzer,js_analysis,redirect_chain
USE_SECURITY_AGENT=true
SECURITY_AGENT_ROLLOUT=1.0
SECURITY_AGENT_TIMEOUT=15
SECURITY_AGENT_RETRY_COUNT=2
SECURITY_AGENT_FAIL_FAST=false
SECURITY_USE_TIER_EXECUTION=true

# Tor / Onion support (experimental)
TOR_ENABLED=false
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050

# Tesseract OCR path (auto-detects if not set)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ========================================
# Frontend Configuration (Next.js)
# ========================================
# API URL for HTTP requests
NEXT_PUBLIC_API_URL=http://localhost:8000
# WebSocket URL for real-time streaming
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ========================================
# CORS Configuration (Backend)
# ========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000